<?xml version='1.0' encoding='utf-8'?>
<OpenSCENARIO xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="OpenScenario.xsd">
    <FileHeader description="straight_crossing_conflict: enter_intersection_go_straight vs go_straight_through_intersection. Cyclist enters the intersection and collides with a passenger car travelling through the crossing approach." author="Shayma" revMajor="1" revMinor="3" date="2026-06-02T15:49:28.566721"/>
    <CatalogLocations/>
    <RoadNetwork>
        <LogicFile filepath="straight_crossing_charlottenburg_2021_10_17.xodr"/>
    </RoadNetwork>
    <Entities>
        <ScenarioObject name="cyclist_1">
            <Vehicle name="cyclist_1" vehicleCategory="bicycle" model3d="cyclist.osgb">
                <BoundingBox>
                    <Center x="0.3" y="0.0" z="0.8"/>
                    <Dimensions width="0.6" length="1.8" height="1.5"/>
                </BoundingBox>
                <Performance maxSpeed="15.0" maxDeceleration="4.0" maxAcceleration="3.0"/>
                <Axles>
