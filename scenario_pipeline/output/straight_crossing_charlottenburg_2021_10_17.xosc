                                </SpeedActionTarget>
                            </SpeedAction>
                        </LongitudinalAction>
                    </PrivateAction>
                </Private>
            </Actions>
        </Init>
        <Story name="story_act_maneuvuergroup_CyclistEnterIntersectionManeuver">
            <Act name="act_maneuvuergroup_CyclistEnterIntersectionManeuver">
                <ManeuverGroup name="maneuvuergroup_CyclistEnterIntersectionManeuver" maximumExecutionCount="1">
                    <Actors selectTriggeringEntities="false">
                        <EntityRef entityRef="cyclist_1"/>
                    </Actors>
                    <Maneuver name="CyclistEnterIntersectionManeuver">
                        <Event name="CyclistEnterIntersectionEvent" priority="override" maximumExecutionCount="1">
                            <Action name="CyclistEnterIntersectionFollowTrajectory">
                                <PrivateAction>
                                    <RoutingAction>
                                        <FollowTrajectoryAction>
                                            <TrajectoryRef>
                                                <Trajectory name="CyclistEnterIntersectionTrajectory" closed="false">
                                                    <Shape>
                                                        <Polyline>
                                                            <Vertex time="0.0">
                                                                <Position>
                                                                    <WorldPosition x="-1.7500000000000013" y="22.25" z="0.0" h="-1.5707963267948966" p="0.0" r="0.0"/>
                                                                </Position>
                                                            </Vertex>
                                                            <Vertex time="3.7">
                                                                <Position>
                                                                    <WorldPosition x="-1.75" y="3.5500000000000003" z="0.0" h="-1.5707963267948966" p="0.0" r="0.0"/>
                                                                </Position>
                                                            </Vertex>
                                                            <Vertex time="4.0">
                                                                <Position>
                                                                    <WorldPosition x="-1.75" y="1.7500000000000002" z="0.0" h="-1.5707963267948966" p="0.0" r="0.0"/>
                                                                </Position>
                                                            </Vertex>
                                                            <Vertex time="9.0">
                                                                <Position>
                                                                    <WorldPosition x="-1.75" y="1.7500000000000002" z="0.0" h="-1.5707963267948966" p="0.0" r="0.0"/>
                                                                </Position>
                                                            </Vertex>
                                                        </Polyline>
                                                    </Shape>
                                                </Trajectory>
                                            </TrajectoryRef>
                                            <TimeReference>
                                                <Timing domainAbsoluteRelative="relative" scale="1.0" offset="0.0"/>
                                            </TimeReference>
                                            <TrajectoryFollowingMode followingMode="position"/>
                                        </FollowTrajectoryAction>
                                    </RoutingAction>
                                </PrivateAction>
                            </Action>
                            <StartTrigger>
                                <ConditionGroup>
                                    <Condition name="CyclistEnterIntersectionStart" delay="0.0" conditionEdge="none">
                                        <ByValueCondition>
                                            <SimulationTimeCondition value="0.1" rule="greaterThan"/>
                                        </ByValueCondition>
                                    </Condition>
                                </ConditionGroup>
                            </StartTrigger>
                        </Event>
                    </Maneuver>
                </ManeuverGroup>
                <StartTrigger>
                    <ConditionGroup>
                        <Condition name="act_start" delay="0.0" conditionEdge="rising">
                            <ByValueCondition>
                                <SimulationTimeCondition value="0.0" rule="greaterThan"/>
                            </ByValueCondition>
                        </Condition>
                    </ConditionGroup>
                </StartTrigger>
                <StopTrigger/>
            </Act>
        </Story>
        <Story name="story_act_maneuvuergroup_CarStraightThroughIntersectionManeuver">
            <Act name="act_maneuvuergroup_CarStraightThroughIntersectionManeuver">
                <ManeuverGroup name="maneuvuergroup_CarStraightThroughIntersectionManeuver" maximumExecutionCount="1">
