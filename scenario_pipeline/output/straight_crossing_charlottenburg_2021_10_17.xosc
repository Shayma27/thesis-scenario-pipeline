                                                                </Position>
                                                            </Vertex>
                                                            <Vertex time="4.0">
                                                                <Position>
                                                                    <WorldPosition x="-1.75" y="1.7500000000000002" z="0.0" h="3.141592653589793" p="0.0" r="0.0"/>
                                                                </Position>
                                                            </Vertex>
                                                            <Vertex time="9.0">
                                                                <Position>
                                                                    <WorldPosition x="-1.75" y="1.7500000000000002" z="0.0" h="3.141592653589793" p="0.0" r="0.0"/>
                                                                </Position>
                                                            </Vertex>
                                                        </Polyline>
                                                    </Shape>
