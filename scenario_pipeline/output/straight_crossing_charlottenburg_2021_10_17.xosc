                    <Maneuver name="CarStraightThroughIntersectionManeuver">
                        <Event name="CarStraightThroughIntersectionEvent" priority="override" maximumExecutionCount="1">
                            <Action name="CarStraightThroughIntersectionFollowTrajectory">
