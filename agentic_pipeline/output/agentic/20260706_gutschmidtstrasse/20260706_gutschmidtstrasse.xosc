                                    <AbsoluteTargetSpeed value="5.5"/>
                                </SpeedActionTarget>
                            </SpeedAction>
                        </LongitudinalAction>
                    </PrivateAction>
                </Private>
            </Actions>
        </Init>
        <Story name="story_act_maneuvuergroup_MotorVehicleManeuverManeuver">
            <Act name="act_maneuvuergroup_MotorVehicleManeuverManeuver">
                <ManeuverGroup name="maneuvuergroup_MotorVehicleManeuverManeuver" maximumExecutionCount="1">
                    <Actors selectTriggeringEntities="false">
                        <EntityRef entityRef="truck_1"/>
                    </Actors>
                    <Maneuver name="MotorVehicleManeuverManeuver">
