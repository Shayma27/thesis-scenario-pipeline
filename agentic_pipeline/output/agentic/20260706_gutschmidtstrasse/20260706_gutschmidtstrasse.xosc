<?xml version='1.0' encoding='utf-8'?>
<OpenSCENARIO xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="OpenScenario.xsd">
    <FileHeader description="right_turn_conflict: turn_right vs go_straight. A truck turned right and collided with an e-bike rider going straight." author="Shayma" revMajor="1" revMinor="3" date="2026-07-06T00:24:54.299106"/>
    <CatalogLocations/>
    <RoadNetwork>
        <LogicFile filepath="intersection_4way.xodr"/>
    </RoadNetwork>
    <Entities>
        <ScenarioObject name="truck_1">
            <Vehicle name="truck_1" vehicleCategory="truck" model3d="truck_yellow.osgb">
                <BoundingBox>
                    <Center x="1.5" y="0.0" z="1.2"/>
                    <Dimensions width="2.5" length="8.0" height="3.0"/>
                </BoundingBox>
                <Performance maxSpeed="30.0" maxDeceleration="6.0" maxAcceleration="4.0"/>
                <Axles>
                    <FrontAxle maxSteering="0.5" wheelDiameter="0.8" trackWidth="2.0" positionX="5.5" positionZ="0.4"/>
                    <RearAxle maxSteering="0.5" wheelDiameter="0.8" trackWidth="2.0" positionX="0.0" positionZ="0.4"/>
                </Axles>
            </Vehicle>
        </ScenarioObject>
        <ScenarioObject name="cyclist_1">
            <Vehicle name="cyclist_1" vehicleCategory="bicycle" model3d="cyclist.osgb">
                <BoundingBox>
                    <Center x="0.3" y="0.0" z="0.8"/>
                    <Dimensions width="0.6" length="1.8" height="1.5"/>
                </BoundingBox>
                <Performance maxSpeed="15.0" maxDeceleration="4.0" maxAcceleration="3.0"/>
                <Axles>
                    <FrontAxle maxSteering="0.0" wheelDiameter="0.3" trackWidth="0.5" positionX="1.2" positionZ="0.15"/>
                    <RearAxle maxSteering="0.0" wheelDiameter="0.3" trackWidth="0.5" positionX="0.0" positionZ="0.15"/>
                </Axles>
            </Vehicle>
        </ScenarioObject>
    </Entities>
    <Storyboard>
        <Init>
            <Actions>
                <Private entityRef="truck_1">
                    <PrivateAction>
                        <TeleportAction>
                            <Position>
                                <LanePosition roadId="0" laneId="-1" s="30.0" offset="0.0"/>
                            </Position>
                        </TeleportAction>
                    </PrivateAction>
                    <PrivateAction>
                        <LongitudinalAction>
                            <SpeedAction>
                                <SpeedActionDynamics dynamicsShape="step" value="1.0" dynamicsDimension="time"/>
                                <SpeedActionTarget>
                                    <AbsoluteTargetSpeed value="3.0"/>
                                </SpeedActionTarget>
                            </SpeedAction>
                        </LongitudinalAction>
                    </PrivateAction>
                </Private>
                <Private entityRef="cyclist_1">
                    <PrivateAction>
                        <TeleportAction>
                            <Position>
